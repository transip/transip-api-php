{
    "name": "transip/transip-mcp-server",
    "description": "MCP (Model Context Protocol) server for the TransIP REST API",
    "license": "Apache-2.0",
    "type": "project",
    "require": {
        "php": "^8.0",
        "transip/transip-api-php": "^6.54",
        "php-http/guzzle7-adapter": "^1.0",
        "symfony/cache": "^5.0 || ^6.0 || ^7.0 || ^8.0"
    },
    "autoload": {
        "psr-4": {
            "Transip\\Api\\MCP\\": "src/"
        }
    },
    "bin": ["bin/server"],
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
